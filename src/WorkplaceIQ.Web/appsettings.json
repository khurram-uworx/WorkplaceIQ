{
  "ConnectionStrings": {
    "Sqlite": "Data Source=App_Data/workplaceiq.db;Pooling=True",
    "PgVector": "Host=localhost;Database=workplaceiq;Username=workplaceiq;Password=workplaceiq",
    "Npgsql": "Host=localhost;Database=workplaceiq;Username=workplaceiq;Password=workplaceiq",
    "SqlServer": "Server=.;Database=workplaceiq;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Storage": {
    "Provider": "sqlite",
    "PgVector": {
      "Schema": "public",
      "Index": {
        "Enabled": true,
        "Method": "hnsw",
        "DistanceFunction": "vector_cosine_ops",
        "M": 16,
        "EfConstruction": 64
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "SignalFlow": {
    "Endpoint": "http://localhost:11434/v1",
    "EmbeddingModel": "nomic-embed-text",
    "LlmModel": "llama3.2:1b",
    "ApiKey": "no-auth",
    "EmbeddingDimension": 768,
    "ConfigDir": "configs"
  }
}
