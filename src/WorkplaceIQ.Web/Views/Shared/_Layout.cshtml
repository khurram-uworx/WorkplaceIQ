<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Workplace Inc.</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkplaceIQ.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="iq-navbar">
        <nav class="navbar navbar-expand-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Workplace Inc.</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="News">News</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Incidents">Incidents</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Discussions">Discussions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Documents">Documents</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="iq-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="iq-footer">
        <div class="container">
            <span>&copy; 2026 Workplace Inc.</span>
        </div>
    </footer>

    <div class="modal fade" id="iqItemActionModal" tabindex="-1" aria-labelledby="iqItemActionModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" class="modal-content" id="iqItemActionForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" id="iqItemActionReturnUrl" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="iqItemActionModalLabel">Item action</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="itemType" id="iqItemActionType" />
                    <input type="hidden" name="itemId" id="iqItemActionId" />

                    <div class="mb-3 iq-modal-field" data-iq-field="title">
                        <label for="iqItemActionTitle" class="form-label">Title</label>
                        <input id="iqItemActionTitle" name="title" class="form-control" />
                    </div>

                    <div class="mb-3 iq-modal-field" data-iq-field="body">
                        <label for="iqItemActionBody" class="form-label">Comment</label>
                        <textarea id="iqItemActionBody" name="body" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3 iq-modal-field" data-iq-field="label">
                        <label for="iqItemActionLabel" class="form-label">Label</label>
                        <input id="iqItemActionLabel" name="label" class="form-control" placeholder="example-label" />
                    </div>

                    <p class="iq-modal-message mb-0" id="iqItemActionMessage"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="iqItemActionSubmit">Save</button>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
