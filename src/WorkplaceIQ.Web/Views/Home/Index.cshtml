@{
    ViewData["Title"] = "Dashboard";
}

<div class="iq-hero">
    <div class="iq-hero__content">
        <h1 class="iq-hero__title">Workplace Inc.</h1>
        <p class="iq-hero__subtitle">
            Internal company portal — news, incidents, discussions, and documents.
        </p>
        <div class="iq-hero__actions">
            <a asp-action="News" class="btn btn-primary">News</a>
            <a asp-action="Incidents" class="btn btn-outline-secondary">Incidents</a>
            <a asp-action="Discussions" class="btn btn-outline-secondary">Discussions</a>
            <a asp-action="Documents" class="btn btn-outline-secondary">Documents</a>
        </div>
    </div>
</div>

<div class="iq-metrics-row mb-4">
    <iq-metric name="workplaceiq.container.content.count"
               source="PowerOutages"
               content-type="Outage"
               window="last_7_days" />
    <iq-metric name="workplaceiq.metadata.sum"
               source="PowerOutages"
               content-type="Outage"
               source-field="durationSeconds"
               window="last_7_days"
               unit="seconds"
               display-unit="hours" />
</div>

@if (TempData["ItemActionMessage"] is string itemActionMessage)
{
    <div class="alert alert-success" role="status">@itemActionMessage</div>
}

<div class="iq-dashboard-grid">
    <a asp-action="News" class="iq-dash-card">
        <div class="iq-dash-card__icon">📢</div>
        <h2 class="iq-dash-card__title">Company News</h2>
        <p class="iq-dash-card__desc">Announcements, product updates, and team highlights.</p>
    </a>
    <a asp-action="Incidents" class="iq-dash-card">
        <div class="iq-dash-card__icon">⚡</div>
        <h2 class="iq-dash-card__title">Incidents</h2>
        <p class="iq-dash-card__desc">Infrastructure outages and engineering incidents.</p>
    </a>
    <a asp-action="Discussions" class="iq-dash-card">
        <div class="iq-dash-card__icon">💬</div>
        <h2 class="iq-dash-card__title">Discussions</h2>
        <p class="iq-dash-card__desc">Engineering forums and team collaboration.</p>
    </a>
    <a asp-action="Documents" class="iq-dash-card">
        <div class="iq-dash-card__icon">📄</div>
        <h2 class="iq-dash-card__title">Documents</h2>
        <p class="iq-dash-card__desc">Policies, runbooks, specs, and HR resources.</p>
    </a>

</div>
