@{
    ViewData["Title"] = "Discussions";
}

<div class="iq-section-header">
    <h1>Discussions</h1>
    <p class="text-muted">Engineering forums and team collaboration. Start a new thread or join an existing conversation.</p>
</div>

@if (TempData["ForumThreadCreated"] is string forumMessage)
{
    <div class="alert alert-success" role="status">@forumMessage</div>
}

<iq-forum id="MaintenanceForum" title="Engineering Forum"></iq-forum>

<form asp-action="CreateForumThread" method="post" class="iq-form-card mt-4">
    <input type="hidden" name="forumId" value="MaintenanceForum" />
    <input type="hidden" name="returnUrl" value="@Url.Action("Discussions")" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label for="forum-thread-title" class="form-label">Title</label>
        <input id="forum-thread-title" name="title" class="form-control" required />
    </div>

    <div class="mb-3">
        <label for="forum-thread-body" class="form-label">Body</label>
        <textarea id="forum-thread-body" name="body" class="form-control" rows="3" required></textarea>
    </div>

    <div class="mb-3">
        <label for="forum-thread-labels" class="form-label">Labels</label>
        <input id="forum-thread-labels" name="labels" class="form-control" placeholder="Engineering, Architecture" />
    </div>

    <button type="submit" class="btn btn-primary">Add thread</button>
</form>
