@using WorkplaceIQ.Content
@using WorkplaceIQ.Labels
@{
    Layout = "_SignalFlowLayout";
    var items = Model as IReadOnlyList<ClassifiedItem> ?? [];
    var label = ViewData["SignalLabel"] as Label;
    var page = (int)ViewData["Page"]!;
    var pageSize = (int)ViewData["PageSize"]!;
    ViewData["Title"] = label?.Name ?? "Signal";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">&larr; Back</a>

<h2 class="mb-1">@label?.Name</h2>
<p class="text-muted mb-3">@items.Count items on this page</p>

@if (items.Count == 0)
{
    <partial name="Shared/_EmptyState" model='@("No items in this signal.")' />
}
else
{
    @foreach (var item in items)
    {
        <partial name="Shared/_ItemRow" model="item" />
    }

    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @if (page > 0)
            {
                <li class="page-item">
                    <a class="page-link" asp-route-signalName="@label?.Name" asp-route-page="@(page - 1)">Previous</a>
                </li>
            }
            <li class="page-item">
                <a class="page-link" asp-route-signalName="@label?.Name" asp-route-page="@(page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
